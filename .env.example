# SDM Industry Search Engine — Environment Variables
# Copy this file to .env and fill in your API keys.

# Apollo.io API Key (required for contact enrichment in Treasury + Events sectors)
# Get yours at: https://app.apollo.io/#/settings/integrations/api_keys
APOLLO_API_KEY=your_key_here

# CanLII API Key (optional, for Canadian case law in Legal sector)
# Register at: https://developer.canlii.org/
# CANLII_API_KEY=your_key_here
