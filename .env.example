# SDM Industry Search Engine — Environment Variables
# Copy this file to .env and fill in your values.
# Only APOLLO_API_KEY is required; everything else has sensible defaults.

# ── Required ─────────────────────────────────────────────────────────────

# Apollo.io API key — used for contact lookups in Treasury and Events sectors
# Get yours at: https://app.apollo.io/#/settings/integrations/api_keys
APOLLO_API_KEY=your_key_here

# ── Optional ─────────────────────────────────────────────────────────────

# CanLII API key — enables Canadian case law search in the Legal sector
# Register for free at: https://developer.canlii.org/
# CANLII_API_KEY=your_key_here

# Server port (default 5055; Render sets this automatically)
# PORT=5055

# ── Cache TTLs (seconds) ────────────────────────────────────────────────

# How long to cache Bitcoin Treasuries company data (default: 86400 = 24 hours)
# BT_CACHE_TTL=86400

# How long to cache legal search results (default: 3600 = 1 hour)
# LEGAL_CACHE_TTL=3600

# How long to cache Luma event scrape results (default: 1800 = 30 minutes)
# EVENT_CACHE_TTL=1800

# ── Advanced (rarely need to change) ────────────────────────────────────

# Apollo API base URL
# APOLLO_API_BASE=https://api.apollo.io/api/v1

# Bitcoin Treasuries API base URL
# BT_API_BASE=https://playground.bitcointreasuries.net/api

# Set to "true" on Render.com (skips auto-install of dependencies)
# RENDER=true
